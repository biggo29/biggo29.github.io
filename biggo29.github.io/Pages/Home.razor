                "API versioning and backward compatibility"
            }
        },
        new Project
        {
            Title = "Healthcare Management System",
            ShortDescription = "Cloud-based healthcare platform with telemedicine capabilities",
            FullDescription = "Comprehensive healthcare management system featuring patient records, appointment scheduling, telemedicine video consultations, prescription management, and billing. HIPAA compliant with end-to-end encryption.",
            Technologies = new() { "ASP.NET Core", "Blazor", "Azure", "SQL Server", "WebRTC", "Azure Storage" },
            ImageUrl = "images/project-healthcare.svg",
            GithubUrl = "https://github.com/biggo29/healthcare-management",
