            }
        },
        new Project
        {
            Title = "CBVMP e-Governance System",
            ShortDescription = "WSIS Award 2021 winner - Digital birth registration and vital statistics system",
            FullDescription = "Civil Birth and Vital Statistics Management Platform (CBVMP) - A comprehensive e-governance solution that digitized birth registration processes across Bangladesh. Winner of WSIS Award 2021 in the e-Government category. Serves millions of citizens with secure, scalable infrastructure.",
            Technologies = new() { "ASP.NET Core", "C#", "Azure", "SQL Server", "Angular", "SignalR", "Azure AD" },
            ImageUrl = "images/project-cbvmp.svg",
            GithubUrl = "",
            DemoUrl = "",
            KeyFeatures = new()
            {
                "Digital birth certificate issuance with blockchain verification",
                "Role-based access control for government officials",
                "Real-time data synchronization across districts",
                "Mobile-responsive interface for field workers",
                "Biometric authentication integration",
                "Comprehensive audit logging and compliance reporting"
            }
        },
        new Project
        {
            Title = "Financial Services API Gateway",
            ShortDescription = "High-performance API gateway for banking and financial services",
            FullDescription = "Enterprise API Gateway solution handling 10,000+ TPS for financial transactions. Implements OAuth 2.0, JWT authentication, rate limiting, and comprehensive logging. Built with .NET Core and deployed on Azure Kubernetes Service.",
            Technologies = new() { ".NET 8", "Azure API Management", "OAuth 2.0", "Redis", "Kubernetes", "Application Insights" },
            ImageUrl = "images/project-api-gateway.svg",
            GithubUrl = "https://github.com/biggo29/financial-api-gateway",
            DemoUrl = "",
            KeyFeatures = new()
            {
                "OAuth 2.0 and JWT token-based authentication",
                "Dynamic rate limiting per client tier",
                "Request/response transformation and validation",
                "Distributed tracing with Application Insights",
