    private List<Project> FilteredProjects => selectedFilter == "All"
        ? projects
        : projects.Where(p => p.Technologies.Contains(selectedFilter)).ToList();

    private void FilterProjects(string filter)
    {
        selectedFilter = filter;
    }

    private void ShowProjectDetails(Project project)
    {
        selectedProject = project;
        showModal = true;
    }

    private void CloseModal()
    {
        showModal = false;
        selectedProject = null;
    }

    private async Task HandleSubmit()
    {
        // In a real application, you would send this to an API
        formMessage = "Thank you for your message! I'll get back to you soon.";
        contactForm = new ContactForm();
        await Task.Delay(3000);
        formMessage = "";
    }

    public class ContactForm
    {
        public string Name { get; set; } = "";
        public string Email { get; set; } = "";
        public string Message { get; set; } = "";
    }
}