@page "/"

<PageTitle>Shoaib Shahriar - Lead Software Engineer</PageTitle>

<section id="home" class="hero-section">
    <div class="hero-content fade-in">
        <div class="hero-text">
            <h1 class="hero-title">Shoaib Shahriar</h1>
            <h2 class="hero-subtitle">Lead Software Engineer | .NET | Microservices | Azure</h2>
            <p class="hero-description">
                8+ years of experience building scalable enterprise applications, eCommerce microservices,
                and award-winning e-Governance solutions. Currently leading engineering teams at EchoLogyx Ltd.
            </p>
            <div class="hero-stats">
                <div class="stat-item">
                    <h3>8+</h3>
                    <p>Years Experience</p>
                </div>
                <div class="stat-item">
                    <h3>50+</h3>
                    <p>Projects Delivered</p>
                </div>
                <div class="stat-item">
                    <h3>WSIS 2021</h3>
                    <p>Award Winner</p>
                </div>
            </div>
            <div class="hero-cta">
                <a href="#projects" class="btn btn-primary">View My Work</a>
                <a href="#contact" class="btn btn-secondary">Get In Touch</a>
            </div>
        </div>
        <div class="hero-image">
            <div class="profile-image-container">
                <img src="images/profile-placeholder.svg" alt="Shoaib Shahriar" class="profile-image" />
            </div>
        </div>
    </div>
</section>

<section id="projects" class="projects-section">
    <div class="section-container">
        <h2 class="section-title">Featured Projects</h2>
        <p class="section-subtitle">Building scalable, enterprise-grade solutions with modern architecture</p>

        <div class='project-filters'>
            <button class='filter-btn @(selectedFilter == "All" ? "active" : "")' @onclick='() => FilterProjects("All")'>All</button>
            <button class='filter-btn @(selectedFilter == "Microservices" ? "active" : "")' @onclick='() => FilterProjects("Microservices")'>Microservices</button>
            <button class='filter-btn @(selectedFilter == ".NET" ? "active" : "")' @onclick='() => FilterProjects(".NET")'>.NET</button>
            <button class='filter-btn @(selectedFilter == "Azure" ? "active" : "")' @onclick='() => FilterProjects("Azure")'>Azure</button>
            <button class='filter-btn @(selectedFilter == "Blazor" ? "active" : "")' @onclick='() => FilterProjects("Blazor")'>Blazor</button>
        </div>

        <div class="projects-grid">
            @foreach (var project in FilteredProjects)
            {
                <div class="project-card" @onclick="() => ShowProjectDetails(project)">
                    <div class="project-image">
                        <img src="@project.ImageUrl" alt="@project.Title" />
                        <div class="project-overlay">
                            <span>View Details</span>
                        </div>
                    </div>
                    <div class="project-content">
                        <h3>@project.Title</h3>
                        <p>@project.ShortDescription</p>
                        <div class="project-tech">
                            @foreach (var tech in project.Technologies)
                            {
                                <span class="tech-badge">@tech</span>
                            }
                        </div>
                        <div class="project-links">
                            @if (!string.IsNullOrEmpty(project.GithubUrl))
                            {
                                <a href="@project.GithubUrl" target="_blank" class="project-link" @onclick:stopPropagation="true">
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                                        <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
                                    </svg>
                                    Code
                                </a>
                            }
                            @if (!string.IsNullOrEmpty(project.DemoUrl))
                            {
                                <a href="@project.DemoUrl" target="_blank" class="project-link" @onclick:stopPropagation="true">
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                                        <polyline points="15 3 21 3 21 9" />
                                        <line x1="10" y1="14" x2="21" y2="3" />
                                    </svg>
                                    Demo
                                </a>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<section id="skills" class="skills-section">
    <div class="section-container">
        <h2 class="section-title">Technical Expertise</h2>
        <p class="section-subtitle">Specializing in enterprise architecture and scalable cloud solutions</p>

        <div class="skills-grid">
            @foreach (var skill in skills)
            {
                <div class="skill-card">
                    <div class="skill-header">
                        <h3>@skill.Name</h3>
                        <span class="skill-level">@skill.Level%</span>
                    </div>
                    <div class="skill-bar">
                        <div class="skill-progress" style="width: @skill.Level%"></div>
                    </div>
                    <div class="skill-tags">
                        @foreach (var tag in skill.SubSkills)
                        {
                            <span class="skill-tag">@tag</span>
                        }
                    </div>
                </div>
            }
        </div>

        <div class="expertise-areas">
            <h3>Core Competencies</h3>
            <div class="competencies-grid">
                <div class="competency-item">
                    <div class="competency-icon">🏗️</div>
                    <h4>Clean Architecture</h4>
                    <p>Domain-Driven Design, CQRS patterns, Event-Driven Systems</p>
                </div>
                <div class="competency-item">
                    <div class="competency-icon">☁️</div>
                    <h4>Cloud Native</h4>
                    <p>Azure services, Kubernetes, Docker, CI/CD pipelines</p>
                </div>
                <div class="competency-item">
                    <div class="competency-icon">🧪</div>
                    <h4>Quality Engineering</h4>
                    <p>TDD, Unit Testing, Integration Testing, Code Reviews</p>
                </div>
                <div class="competency-item">
                    <div class="competency-icon">👥</div>
                    <h4>Technical Leadership</h4>
                    <p>Team mentoring, Architecture decisions, Agile practices</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section id="github" class="github-section">
    <div class="section-container">
        <h2 class="section-title">GitHub Activity</h2>
        <p class="section-subtitle">Open source contributions and code statistics</p>

        <div class="github-stats">
            <div class="github-card">
                <img src="https://github-readme-stats.vercel.app/api?username=biggo29&show_icons=true&theme=tokyonight&hide_border=true&count_private=true"
                     alt="GitHub Stats" />
            </div>
            <div class="github-card">
                <img src="https://github-readme-stats.vercel.app/api/top-langs/?username=biggo29&layout=compact&theme=tokyonight&hide_border=true&langs_count=8"
                     alt="Top Languages" />
            </div>
        </div>

        <div class="github-streak">
            <img src="https://github-readme-streak-stats.herokuapp.com/?user=biggo29&theme=tokyonight&hide_border=true"
                 alt="GitHub Streak" />
        </div>

        <div class="github-profile-link">
            <a href="https://github.com/biggo29" target="_blank" class="btn btn-primary">
                View Full GitHub Profile
            </a>
        </div>
    </div>
</section>

<section id="contact" class="contact-section">
    <div class="section-container">
        <h2 class="section-title">Let's Connect</h2>
        <p class="section-subtitle">Interested in collaboration or have a project in mind?</p>

        <div class="contact-content">
            <div class="contact-info">
                <div class="contact-item">
                    <div class="contact-icon">📧</div>
                    <div>
                        <h4>Email</h4>
                        <a href="mailto:shoaibshahriar29@gmail.com">shoaibshahriar29@gmail.com</a>
                    </div>
                </div>
                <div class="contact-item">
                    <div class="contact-icon">💼</div>
                    <div>
                        <h4>LinkedIn</h4>
                        <a href="https://linkedin.com/in/shoaib-shahriar" target="_blank">linkedin.com/in/shoaib-shahriar</a>
                    </div>
                </div>
                <div class="contact-item">
                    <div class="contact-icon">🐙</div>
                    <div>
                        <h4>GitHub</h4>
                        <a href="https://github.com/biggo29" target="_blank">github.com/biggo29</a>
                    </div>
                </div>
                <div class="contact-item">
                    <div class="contact-icon">🌐</div>
                    <div>
                        <h4>Portfolio</h4>
                        <a href="https://biggo29.github.io" target="_blank">biggo29.github.io</a>
                    </div>
                </div>
            </div>

            <div class="contact-form">
                <h3>Send a Message</h3>
                <form @onsubmit="HandleSubmit">
                    <div class="form-group">
                        <input type="text" placeholder="Your Name" @bind="contactForm.Name" required />
                    </div>
                    <div class="form-group">
                        <input type="email" placeholder="Your Email" @bind="contactForm.Email" required />
                    </div>
                    <div class="form-group">
                        <textarea placeholder="Your Message" rows="5" @bind="contactForm.Message" required></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary">Send Message</button>
                </form>
                @if (!string.IsNullOrEmpty(formMessage))
                {
                    <div class="form-message">@formMessage</div>
                }
            </div>
        </div>
    </div>
</section>

@if (showModal && selectedProject != null)
{
    <div class="modal-overlay" @onclick="CloseModal">
        <div class="modal-content" @onclick:stopPropagation="true">
            <button class="modal-close" @onclick="CloseModal">&times;</button>
            <div class="modal-header">
                <h2>@selectedProject.Title</h2>
            </div>
            <div class="modal-body">
                <img src="@selectedProject.ImageUrl" alt="@selectedProject.Title" class="modal-image" />
                <p class="modal-description">@selectedProject.FullDescription</p>
                <div class="modal-section">
                    <h3>Technologies Used</h3>
                    <div class="modal-tech">
                        @foreach (var tech in selectedProject.Technologies)
                        {
                            <span class="tech-badge">@tech</span>
                        }
                    </div>
                </div>
                <div class="modal-section">
                    <h3>Key Features</h3>
                    <ul class="feature-list">
                        @foreach (var feature in selectedProject.KeyFeatures)
                        {
                            <li>@feature</li>
                        }
                    </ul>
                </div>
                <div class="modal-links">
                    @if (!string.IsNullOrEmpty(selectedProject.GithubUrl))
                    {
                        <a href="@selectedProject.GithubUrl" target="_blank" class="btn btn-primary">View Code</a>
                    }
                    @if (!string.IsNullOrEmpty(selectedProject.DemoUrl))
                    {
                        <a href="@selectedProject.DemoUrl" target="_blank" class="btn btn-secondary">Live Demo</a>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
