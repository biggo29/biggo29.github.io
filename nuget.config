<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSourceMapping>
    <!-- Allow Blazor WebAssembly packages from nuget.org.
         The global NuGet.Config has source mapping that omits these,
         causing restore to fail for any version not already in cache. -->
    <packageSource key="nuget.org">
      <package pattern="Microsoft.AspNetCore.Components.WebAssembly" />
      <package pattern="Microsoft.AspNetCore.Components.WebAssembly.DevServer" />
    </packageSource>
  </packageSourceMapping>
</configuration>
