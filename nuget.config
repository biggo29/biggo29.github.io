<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSourceMapping>
    <!-- Allow all packages from nuget.org, including implicit SDK packages
         (e.g. Microsoft.NET.ILLink.Tasks, Microsoft.DotNet.HotReload.WebAssembly.Browser)
         that are not referenced directly but are required by the Blazor WASM SDK. -->
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
