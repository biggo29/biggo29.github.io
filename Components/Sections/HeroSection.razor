@inject IJSRuntime JS

<section id="home" class="hero" aria-label="Introduction">
    <div class="hero-inner">

        <!-- ── Left: identity & CTAs ───────────────────────── -->
        <div class="hero-left">
            <p class="hero-eyebrow">Lead Software Engineer · Dhaka, Bangladesh</p>

            <h1 class="hero-name">Shoaib Shahriar</h1>

            <!--
                aria-label provides the full text for screen readers immediately.
                The visible text is typed in progressively by startTypewriter().
            -->
            <p class="hero-role" aria-label="Backend Architect · .NET · Microservices · Azure">
                <span class="hero-role-typed" @ref="_roleTypedRef"></span><span class="hero-role-cursor" aria-hidden="true"></span>
            </p>

            <p class="hero-statement">
                I design scalable backend systems, distributed microservices, and enterprise APIs
                using .NET, Azure, and modern architecture practices.
            </p>

            <div class="hero-chips">
                <MetricChip Icon="⚡" Text="8+ Years Experience" />
                <MetricChip Icon="🔗" Text="30+ Microservices" />
                <MetricChip Icon="🏆" Text="WSIS Award 2021" />
                <MetricChip Icon="👥" Text="Technical Leadership" />
            </div>

            <div class="hero-actions">
                <PrimaryButton  Text="View Case Studies" Href="#case-studies" />
                <SecondaryButton Text="Contact Me"        Href="#contact" />
                <SecondaryButton Text="Resume ↓"          Href="files/ResumeShoaibShahriar.pdf" Target="_blank" AriaLabel="Download resume PDF" />
            </div>
        </div>

        <!-- ── Right: photo + engineering stack panel ─────── -->
        <div class="hero-right" aria-hidden="true">

            <!-- Profile photo — swap src to update everywhere -->
            <div class="hero-photo-wrapper">
                <img
                    src="images/biggo-photo-ai.png"
                    alt="Shoaib Shahriar"
                    class="hero-photo"
                    loading="eager"
                    width="160"
                    height="160" />
                <div class="hero-photo-ring" aria-hidden="true"></div>
                <div class="hero-photo-glow"  aria-hidden="true"></div>
            </div>

            <div class="stack-panel">
                <div class="stack-panel-header">
                    <span class="dot dot-red"></span>
                    <span class="dot dot-yellow"></span>
                    <span class="dot dot-green"></span>
                    <span class="panel-label">stack.overview</span>
                </div>
                <div class="stack-panel-body">
                    @foreach (var group in StackGroups)
                    {
                        <div class="stack-group">
                            <p class="stack-group-label">
                                <span>@group.Icon</span>@group.Label
                            </p>
                            <div class="stack-tags">
                                @foreach (var tag in group.Tags)
                                {
                                    <TagBadge Text="@tag" />
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

    </div>
</section>

@code {
    private record StackGroup(string Icon, string Label, string[] Tags);

    private ElementReference _roleTypedRef;

    private static readonly StackGroup[] StackGroups =
    {
        new("⚙️ ", "Backend",
            new[] { "C#", "ASP.NET Core", ".NET 8", "EF Core", "LINQ" }),

        new("🏗️ ", "Architecture",
            new[] { "CQRS", "Clean Architecture", "Microservices", "Event-Driven" }),

        new("☁️ ", "Cloud & DevOps",
            new[] { "Azure DevOps", "CI/CD", "Docker", "Observability" }),

        new("🧪 ", "Quality",
            new[] { "TDD", "XUnit", "MSpec", "99%+ Coverage" }),

        new("🤖 ", "AI-Assisted Dev",
            new[] { "GitHub Copilot", "Claude", "ChatGPT" }),
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // hero-role stagger: delay 0.20 s + duration 0.50 s = visible at 0.70 s.
            // 820 ms gives a natural 120 ms cursor-blink pause before typing begins.
            await JS.InvokeVoidAsync(
                "startTypewriter",
                _roleTypedRef,
                "Backend Architect · .NET · Microservices · Azure",
                40,    // ms per character
                820);  // ms before first character appears
        }
    }
}
