@using System.Text.Json.Serialization
@inject MediumService MediumSvc
@inject IJSRuntime JSRuntime

<section id="writing" class="med-section" aria-label="Medium Articles">
    <div class="med-inner">

        <SectionTitle Title="Writing"
                      Subtitle="Technical articles on .NET, microservices, architecture, and engineering at scale." />

        @if (_loading)
        {
            <p class="med-status" role="status">Loading articles…</p>
        }
        else if (_articles.Count == 0)
        {
            <p class="med-status">No articles found. Check back soon.</p>
        }
        else
        {
            <div class="med-carousel-wrapper"
                 role="region"
                 aria-label="Articles slider"
                 aria-roledescription="carousel">

                <div class="med-track @(_articles.Count >= 3 ? "is-slider" : "")"
                     @ref="_trackRef">

                    @foreach (var article in _articles)
                    {
                        <article class="med-card" aria-roledescription="slide">
                            @if (!string.IsNullOrEmpty(article.Thumbnail))
                            {
                                <img class="med-thumb"
                                     src="@article.Thumbnail"
                                     alt="@article.Title"
                                     loading="lazy" />
                            }
                            else
                            {
                                <div class="med-thumb-placeholder" aria-hidden="true">@AppIcons.Medium</div>
                            }

                            <div class="med-body">
                                <time class="med-date">@article.PubDate</time>
                                <h3 class="med-title">@article.Title</h3>
                                <p class="med-desc">@article.Description</p>
                                <a class="med-read-more"
                                   href="@article.Link"
                                   target="_blank"
                                   rel="noopener noreferrer"
                                   aria-label="Read @article.Title on Medium (opens in new tab)">
                                    Read on Medium <span aria-hidden="true">→</span>
                                </a>
                            </div>
                        </article>
                    }
                </div>
            </div>

            @if (_articles.Count >= 3)
            {
                <div class="med-controls" role="group" aria-label="Carousel navigation">

                    <button class="med-nav-btn"
                            @onclick="PrevAsync"
                            disabled="@(!_canPrev)"
                            aria-label="Show previous articles">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18"
                             viewBox="0 0 24 24" fill="none" stroke="currentColor"
                             stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"
                             aria-hidden="true">
                            <polyline points="15 18 9 12 15 6" />
                        </svg>
                    </button>

                    <div class="med-progress"
                         role="progressbar"
                         aria-valuenow="@_progress"
                         aria-valuemin="0"
                         aria-valuemax="100"
                         aria-label="Article carousel progress">
                        <div class="med-progress-fill" style="width: @_progress%"></div>
                    </div>

                    <button class="med-nav-btn"
                            @onclick="NextAsync"
                            disabled="@(!_canNext)"
                            aria-label="Show next articles">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18"
                             viewBox="0 0 24 24" fill="none" stroke="currentColor"
                             stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"
                             aria-hidden="true">
                            <polyline points="9 18 15 12 9 6" />
                        </svg>
                    </button>

                </div>
            }
        }

        <div class="med-cta">
            <PrimaryButton Text="View All Articles"
                           Href="@_mediumUrl"
                           Target="_blank"
                           Icon="medium"
                           AriaLabel="View all articles on Medium (opens in new tab)" />
        </div>

    </div>
</section>

@code {
    private List<MediumArticle> _articles = new();
    private bool _loading = true;
    private const string _mediumUrl = "https://medium.com/@biggo29";

    private ElementReference _trackRef;
    private bool _canPrev;
    private bool _canNext = true;   // optimistic default — corrected after first sync
    private int  _progress;
    private bool _carouselReady;

    protected override async Task OnInitializedAsync()
    {
        _articles = await MediumSvc.GetArticlesAsync();
        _loading  = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_loading && !_carouselReady && _articles.Count >= 3)
        {
            _carouselReady = true;
            await SyncStateAsync();
            StateHasChanged();
        }
    }

    private async Task PrevAsync()
    {
        await JSRuntime.InvokeVoidAsync("carouselScroll", _trackRef, -1);
        await Task.Delay(350);
        await SyncStateAsync();
    }

    private async Task NextAsync()
    {
        await JSRuntime.InvokeVoidAsync("carouselScroll", _trackRef, 1);
        await Task.Delay(350);
        await SyncStateAsync();
    }

    private async Task SyncStateAsync()
    {
        var s    = await JSRuntime.InvokeAsync<CarouselState>("getCarouselState", _trackRef);
        _canPrev = s.CanPrev;
        _canNext = s.CanNext;
        _progress = s.Progress;
    }

    private record CarouselState(
        [property: JsonPropertyName("canPrev")]      bool CanPrev,
        [property: JsonPropertyName("canNext")]      bool CanNext,
        [property: JsonPropertyName("currentIndex")] int  CurrentIndex,
        [property: JsonPropertyName("progress")]     int  Progress
    );
}
