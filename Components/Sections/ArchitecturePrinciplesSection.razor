<section id="architecture" class="arch-section" aria-label="Technical Profile">
    <div class="arch-inner">

        <SectionTitle Title="Technical Profile"
                      Subtitle="The engineering philosophy and skills behind the systems I design and deliver." />

        <div class="arch-tabs" role="tablist" aria-label="Technical profile tabs">
            <button class="arch-tab @(_activeTab == "arch" ? "active" : "")"
                    role="tab"
                    aria-selected="@(_activeTab == "arch" ? "true" : "false")"
                    @onclick='() => _activeTab = "arch"'>
                @AppIcons.Get("layers") Architecture Principles
            </button>
            <button class="arch-tab @(_activeTab == "skills" ? "active" : "")"
                    role="tab"
                    aria-selected="@(_activeTab == "skills" ? "true" : "false")"
                    @onclick='() => _activeTab = "skills"'>
                @AppIcons.Get("bolt") Skills
            </button>
        </div>

        @if (_activeTab == "arch")
        {
            <div class="arch-grid" role="tabpanel" aria-label="Architecture Principles">
                @for (var i = 0; i < PortfolioData.ArchitecturePrinciples.Count; i++)
                {
                    var principle = PortfolioData.ArchitecturePrinciples[i];
                    var idx       = i;
                    var open      = _openArchIdx == idx;

                    <div class="arch-card @(open ? "is-open" : "")"
                         @onclick="() => ToggleArch(idx)"
                         role="button"
                         tabindex="0"
                         aria-expanded="@(open ? "true" : "false")"
                         @onkeydown="e => OnArchKeyDown(e, idx)">
                        <div class="arch-card-header">
                            <span class="arch-icon" aria-hidden="true">@AppIcons.Get(principle.Icon)</span>
                            <h3 class="arch-title">@principle.Title</h3>
                            <svg class="arch-chevron @(open ? "is-open" : "")"
                                 xmlns="http://www.w3.org/2000/svg" width="14" height="14"
                                 viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                 stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"
                                 aria-hidden="true">
                                <polyline points="6 9 12 15 18 9" />
                            </svg>
                        </div>
                        <div class="arch-desc-wrap @(open ? "is-visible" : "")">
                            <div class="arch-desc-inner">
                                <p class="arch-desc">@principle.Description</p>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="cap-toolbar">
                <span class="cap-open-count">@_openSkills.Count / @PortfolioData.CapabilityGroups.Count expanded</span>
                <button class="cap-toggle-all" @onclick="ToggleAllSkills"
                        aria-label="@(AllSkillsExpanded ? "Collapse all skill groups" : "Expand all skill groups")">
                    @(AllSkillsExpanded ? "↑ Collapse All" : "↓ Expand All")
                </button>
            </div>

            <div class="cap-grid" role="tabpanel" aria-label="Skills">
                @for (var i = 0; i < PortfolioData.CapabilityGroups.Count; i++)
                {
                    var group = PortfolioData.CapabilityGroups[i];
                    var idx   = i;
                    var open  = _openSkills.Contains(idx);

                    <div class="cap-card @(open ? "is-open" : "")"
                         @onclick="() => ToggleSkill(idx)"
                         role="button"
                         tabindex="0"
                         aria-expanded="@(open ? "true" : "false")"
                         @onkeydown="e => OnSkillKeyDown(e, idx)">
                        <div class="cap-card-header">
                            <div class="cap-header-text">
                                <h3 class="cap-title">@group.Title</h3>
                                @if (!string.IsNullOrEmpty(group.Description))
                                {
                                    <p class="cap-desc">@group.Description</p>
                                }
                            </div>
                            <svg class="cap-chevron @(open ? "is-open" : "")"
                                 xmlns="http://www.w3.org/2000/svg" width="14" height="14"
                                 viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                 stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"
                                 aria-hidden="true">
                                <polyline points="6 9 12 15 18 9" />
                            </svg>
                        </div>
                        <div class="cap-tags-wrap @(open ? "is-visible" : "")">
                            <div class="cap-tags-inner">
                                <div class="cap-tags">
                                    @foreach (var item in group.Items)
                                    {
                                        <TagBadge Text="@item" />
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }

    </div>
</section>

@code {
    private string _activeTab = "arch";

    // Architecture: accordion — only one card open at a time
    private int? _openArchIdx;

    // Skills: multi-open with expand/collapse all
    private readonly HashSet<int> _openSkills = new();

    private bool AllSkillsExpanded =>
        PortfolioData.CapabilityGroups.Count > 0 &&
        _openSkills.Count == PortfolioData.CapabilityGroups.Count;

    private void ToggleArch(int i) =>
        _openArchIdx = _openArchIdx == i ? null : i;

    private void ToggleSkill(int i)
    {
        if (!_openSkills.Remove(i)) _openSkills.Add(i);
    }

    private void ToggleAllSkills()
    {
        if (AllSkillsExpanded)
            _openSkills.Clear();
        else
            for (var i = 0; i < PortfolioData.CapabilityGroups.Count; i++) _openSkills.Add(i);
    }

    private void OnArchKeyDown(KeyboardEventArgs e, int idx)
    {
        if (e.Key == "Enter" || e.Key == " ") ToggleArch(idx);
    }

    private void OnSkillKeyDown(KeyboardEventArgs e, int idx)
    {
        if (e.Key == "Enter" || e.Key == " ") ToggleSkill(idx);
    }
}
