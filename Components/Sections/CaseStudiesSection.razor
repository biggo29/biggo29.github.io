@inject IJSRuntime JS

<section id="case-studies" class="cs-section" aria-label="Case Studies">
    <div class="cs-inner">

        <SectionTitle Title="Case Studies"
                      Subtitle="Flagship projects from production engineering — real systems, real scale, real impact." />

        <div class="cs-filters" role="group" aria-label="Filter case studies by category">
            @foreach (var filter in Filters)
            {
                <button class="cs-filter-btn @(_activeFilter == filter.Value ? "active" : "")"
                        @onclick="() => SetFilter(filter.Value)"
                        aria-pressed="@(_activeFilter == filter.Value ? "true" : "false")">
                    @filter.Label
                </button>
            }
        </div>

        <div class="cs-list">
            @foreach (var study in FilteredStudies)
            {
                <CaseStudyCard Study="@study" />
            }
        </div>

    </div>
</section>

@code {
    private string _activeFilter = "All";
    private bool   _needsCardInit;

    private static readonly (string Label, string Value)[] Filters =
    {
        ("All",           "All"),
        (".NET",          "DotNet"),
        ("Microservices", "Microservices"),
        ("Public Sector", "PublicSector"),
    };

    private IEnumerable<CaseStudy> FilteredStudies =>
        _activeFilter == "All"
            ? PortfolioData.CaseStudies
            : PortfolioData.CaseStudies.Where(c => c.Categories.Contains(_activeFilter));

    private void SetFilter(string filter)
    {
        if (_activeFilter == filter) return;
        _activeFilter    = filter;
        _needsCardInit   = true;     // signal OnAfterRenderAsync to re-init
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Re-run on filter change so newly rendered .cs-cards are picked up
        // by IntersectionObserver and animate in. The flag prevents redundant
        // calls on any other re-render that doesn't change the card list.
        if (_needsCardInit)
        {
            _needsCardInit = false;
            await JS.InvokeVoidAsync("initializeCardAnimations");
        }
    }
}
