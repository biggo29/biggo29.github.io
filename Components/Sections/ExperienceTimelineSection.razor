<section id="experience" class="exp-section" aria-label="Experience & Education">
    <div class="exp-inner">

        <SectionTitle Title="Experience"
                      Subtitle="Career progression across enterprise product, national e-governance, and digital signage engineering." />

        <div class="exp-timeline">
            @for (var i = 0; i < PortfolioData.ExperienceItems.Count; i++)
            {
                var item = PortfolioData.ExperienceItems[i];
                var idx  = i;
                var open = _expanded.Contains(idx);

                <div class="exp-entry">
                    <div class="exp-dot" aria-hidden="true"></div>
                    <div class="exp-card @(open ? "is-expanded" : "")">

                        <button class="exp-card-header exp-toggle"
                                @onclick="() => Toggle(idx)"
                                aria-expanded="@(open ? "true" : "false")">
                            <div class="exp-role-info">
                                <h3 class="exp-role">@item.Role</h3>
                                <div class="exp-meta">
                                    <span class="exp-company">@item.Company</span>
                                    @if (!string.IsNullOrEmpty(item.Client))
                                    {
                                        <span class="exp-separator" aria-hidden="true">·</span>
                                        <span class="exp-client">@item.Client</span>
                                    }
                                </div>
                            </div>
                            <div class="exp-toggle-right">
                                <span class="exp-duration">@item.Duration</span>
                                <svg class="exp-chevron @(open ? "is-open" : "")"
                                     xmlns="http://www.w3.org/2000/svg" width="16" height="16"
                                     viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                     stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"
                                     aria-hidden="true">
                                    <polyline points="6 9 12 15 18 9" />
                                </svg>
                            </div>
                        </button>

                        <div class="exp-details @(open ? "is-visible" : "")" aria-hidden="@(open ? "false" : "true")">
                            <div class="exp-details-inner">
                                <p class="exp-summary">@item.Summary</p>

                                <ul class="exp-accomplishments" aria-label="Key accomplishments">
                                    @foreach (var acc in item.Accomplishments)
                                    {
                                        <li>@acc</li>
                                    }
                                </ul>

                                <div class="exp-tech">
                                    @foreach (var tech in item.Technologies)
                                    {
                                        <TagBadge Text="@tech" />
                                    }
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            }
        </div>

        <div class="edu-divider">
            <h2 class="edu-section-title">Education</h2>
        </div>

        <div class="edu-grid">
            @foreach (var edu in PortfolioData.EducationItems)
            {
                <div class="edu-card">
                    <span class="edu-icon" aria-hidden="true">🎓</span>
                    <div class="edu-content">
                        <h3 class="edu-degree">@edu.Degree</h3>
                        <p class="edu-institution">@edu.Institution</p>
                        <p class="edu-duration">@edu.Duration</p>
                        @if (!string.IsNullOrEmpty(edu.ResearchTopic))
                        {
                            <p class="edu-research">Research: @edu.ResearchTopic</p>
                        }
                    </div>
                </div>
            }
        </div>

    </div>
</section>

@code {
    private readonly HashSet<int> _expanded = new() { 0 };

    private void Toggle(int i)
    {
        if (!_expanded.Remove(i)) _expanded.Add(i);
    }
}
