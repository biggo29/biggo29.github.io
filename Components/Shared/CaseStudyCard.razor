@if (Study is not null)
{
    <article class="cs-card">

        <div class="cs-card-header">
            <span class="cs-role-badge">@Study.Role</span>
            <div class="cs-links">
                @if (!string.IsNullOrEmpty(Study.LiveUrl))
                {
                    <a class="cs-link"
                       href="@Study.LiveUrl"
                       target="_blank"
                       rel="noopener noreferrer"
                       aria-label="View @Study.Title platform">
                        View Platform →
                    </a>
                }
                @if (!string.IsNullOrEmpty(Study.DetailsUrl))
                {
                    <a class="cs-link cs-link-award"
                       href="@Study.DetailsUrl"
                       target="_blank"
                       rel="noopener noreferrer"
                       aria-label="View WSIS award details">
                        WSIS Award →
                    </a>
                }
                @if (!string.IsNullOrEmpty(Study.RepositoryUrl))
                {
                    <a class="cs-link"
                       href="@Study.RepositoryUrl"
                       target="_blank"
                       rel="noopener noreferrer"
                       aria-label="View code for @Study.Title">
                        View Code →
                    </a>
                }
            </div>
        </div>

        <h3 class="cs-title">@Study.Title</h3>
        <p class="cs-context">@Study.Context</p>

        <div class="cs-detail-block cs-architecture">
            <p class="cs-detail-label">Architecture</p>
            <p class="cs-detail-text">@Study.Architecture</p>
        </div>

        <div class="cs-detail-block cs-outcome">
            <p class="cs-outcome-label">Outcome</p>
            <p class="cs-detail-text">@Study.Outcome</p>
        </div>

        <div class="cs-tech-row">
            @foreach (var tag in Study.Technologies.Take(9))
            {
                <TagBadge Text="@tag" />
            }
            @if (Study.Technologies.Count > 9)
            {
                <span class="cs-more">+@(Study.Technologies.Count - 9) more</span>
            }
        </div>

    </article>
}

@code {
    [Parameter, EditorRequired] public CaseStudy? Study { get; set; }
}
