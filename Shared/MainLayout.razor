@inherits LayoutComponentBase
@inject IJSRuntime JSRuntime

<!-- Scroll progress bar — filled by initializeScrollProgress() -->
<div id="scroll-progress-bar" aria-hidden="true"></div>

<!-- Cursor spotlight — radial glow at --cx/--cy set by initializeCursorSpotlight() -->
<div class="cursor-spotlight" aria-hidden="true"></div>

<a href="#main-content" class="skip-link">Skip to main content</a>

<header class="header" role="banner">
    <nav class="nav-container" aria-label="Main navigation">

        <a class="nav-brand" href="/" aria-label="Shoaib Shahriar - Home">SS</a>

        <button class="nav-toggle @(_mobileOpen ? "is-open" : "")"
                @onclick="ToggleMobileMenu"
                aria-expanded="@(_mobileOpen ? "true" : "false")"
                aria-controls="nav-menu"
                aria-label="@(_mobileOpen ? "Close menu" : "Open menu")">
            <span class="nav-toggle-bar"></span>
            <span class="nav-toggle-bar"></span>
            <span class="nav-toggle-bar"></span>
        </button>

        <ul class="nav-links @(_mobileOpen ? "is-open" : "")" id="nav-menu" role="list">
            @foreach (var item in NavItems)
            {
                <li>
                    <a class="nav-link"
                       href="#@item.SectionId"
                       @onclick="() => HandleNavClick(item.SectionId)"
                       @onclick:preventDefault>
                        @item.Label
                    </a>
                </li>
            }
        </ul>

        <button class="theme-toggle-btn"
                @onclick="ToggleThemeAsync"
                aria-label="@(_isDark ? "Switch to light theme" : "Switch to dark theme")"
                title="@(_isDark ? "Light mode" : "Dark mode")">
            @if (_isDark)
            {
                <!-- Sun icon — shown in dark mode to offer switching to light -->
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                     fill="none" stroke="currentColor" stroke-width="2"
                     stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <circle cx="12" cy="12" r="4" />
                    <line x1="12" y1="2"  x2="12" y2="4" />
                    <line x1="12" y1="20" x2="12" y2="22" />
                    <line x1="4.22" y1="4.22"  x2="5.64" y2="5.64" />
                    <line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
                    <line x1="2"  y1="12" x2="4"  y2="12" />
                    <line x1="20" y1="12" x2="22" y2="12" />
                    <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" />
                    <line x1="18.36" y1="5.64"  x2="19.78" y2="4.22" />
                </svg>
            }
            else
            {
                <!-- Moon icon — shown in light mode to offer switching to dark -->
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                     fill="none" stroke="currentColor" stroke-width="2"
                     stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
                </svg>
            }
        </button>

    </nav>
</header>

<main id="main-content">
    @Body
</main>

<footer class="footer" role="contentinfo">
    <div class="footer-content">
        <p class="footer-copy">&copy; @DateTime.Now.Year Shoaib Shahriar</p>
        <div class="social-links">
            <a href="https://github.com/biggo29"
               target="_blank" rel="noopener noreferrer"
               aria-label="Visit GitHub profile (opens in new tab)">
                <span class="footer-social-icon" aria-hidden="true">@AppIcons.GitHub</span>GitHub
            </a>
            <a href="https://linkedin.com/in/biggo29"
               target="_blank" rel="noopener noreferrer"
               aria-label="Connect on LinkedIn (opens in new tab)">
                <span class="footer-social-icon" aria-hidden="true">@AppIcons.LinkedIn</span>LinkedIn
            </a>
            <a href="mailto:shoaibshahriar29@gmail.com"
               aria-label="Send an email">
                <span class="footer-social-icon" aria-hidden="true">@AppIcons.Email</span>Email
            </a>
        </div>
    </div>
</footer>

<!-- Back to top button — visibility toggled by initializeBackToTop() in site.js -->
<button class="back-to-top"
        id="back-to-top"
        @onclick="ScrollToTopAsync"
        aria-label="Scroll back to top">
    <svg xmlns="http://www.w3.org/2000/svg"
         width="18" height="18"
         viewBox="0 0 24 24"
         fill="none"
         stroke="currentColor"
         stroke-width="2.5"
         stroke-linecap="round"
         stroke-linejoin="round"
         aria-hidden="true">
        <polyline points="18 15 12 9 6 15" />
    </svg>
</button>

@code {
    private bool _mobileOpen;
    private bool _isDark = true;

    private static readonly (string Label, string SectionId)[] NavItems =
    {
        ("Home",         "home"),
        ("Impact",       "impact"),
        ("Case Studies", "case-studies"),
        ("Technical",    "architecture"),
        ("Experience",   "experience"),
        ("GitHub",       "github"),
        ("Certificates", "certificates"),
        ("Writing",      "writing"),
        ("Contact",      "contact")
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var theme = await JSRuntime.InvokeAsync<string>("initializeTheme");
            _isDark = theme != "light";
            StateHasChanged();

            await JSRuntime.InvokeVoidAsync("initializeSectionObserver");
            await JSRuntime.InvokeVoidAsync("initializeNavHighlight");
            await JSRuntime.InvokeVoidAsync("initializeBackToTop");
            await JSRuntime.InvokeVoidAsync("initializeCardAnimations");

            // Enhancement layer — all progressive, fail gracefully without JS
            await JSRuntime.InvokeVoidAsync("initializeScrollProgress");
            await JSRuntime.InvokeVoidAsync("initializeCursorSpotlight");
            await JSRuntime.InvokeVoidAsync("initializeSectionNav");
            await JSRuntime.InvokeVoidAsync("initializeTilt");
            await JSRuntime.InvokeVoidAsync("initializeParticleBurst");
            await JSRuntime.InvokeVoidAsync("initializeMagneticButtons");
        }
    }

    private async Task ToggleThemeAsync()
    {
        var next = await JSRuntime.InvokeAsync<string>("toggleTheme");
        _isDark = next != "light";
        await JSRuntime.InvokeVoidAsync("triggerThemeSparkle", ".theme-toggle-btn");
    }

    private async Task HandleNavClick(string sectionId)
    {
        _mobileOpen = false;
        await JSRuntime.InvokeVoidAsync("scrollToSection", sectionId);
    }

    private async Task ScrollToTopAsync()
    {
        await JSRuntime.InvokeVoidAsync("scrollToSection", "home");
    }

    private void ToggleMobileMenu() => _mobileOpen = !_mobileOpen;
}
